  "keyFeatures": [
    "Liveness-based asset release via periodic heartbeat transactions",
    "Multi-asset vaults supporting both sBTC (Bitcoin-backed) and USDCx (stable)",
    "Up to 10 beneficiaries with configurable basis-point percentage splits",
    "Configurable heartbeat interval and grace period per vault",
    "Optional guardian that can extend the grace period once by 30 days",
    "Emergency withdrawal allowing vault owners to reclaim assets at any time before distribution",
    "Updateable heir list while vault is active",
    "Heir auto-discovery via Hiro API transaction scanning",
    "Trustless on-chain execution with no custodians or lawyers required",
    "Vault state computed dynamically from block timestamps — never stale"
  ],
  "publicApiSurface": [
    "create-vault(heartbeat-interval, grace-period, heirs-data, guardian)",
    "deposit-sbtc(amount)",
    "deposit-usdcx(amount)",
    "heartbeat()",
